# ── Frontend env (Vite) ───────────────────────────────────────────────────
# Copy this file to .env.local and fill in. Vite only exposes vars prefixed
# with VITE_ to client code.

# Base URL of the NYC Stoop API. Local dev: http://localhost:8000
# Production (Cloud Run): https://nyc-stoop-api-XXXX.run.app
VITE_API_URL=http://localhost:8000

# Google OAuth web client ID. Get from Google Cloud Console → Credentials.
# Must match the GOOGLE_CLIENT_ID on the backend.
VITE_GOOGLE_CLIENT_ID=

# Google Maps API key — used by the "+ Add a place" search in My Trip to fetch
# Google Places autocomplete + details. SEPARATE credential from the OAuth ID.
# Google Cloud Console → APIs & Services → Credentials → Create credentials →
#   API key. Restrict to:
#     - Application restrictions → HTTP referrers
#         http://localhost:5173/*
#         https://nyc-stoop.vercel.app/*
#     - API restrictions → "Places API (New)" only
# Then APIs & Services → Quotas → Places API → set a daily request cap (e.g. 1000).
# Leave blank to disable Google Places search; the modal will just use local results.
VITE_GOOGLE_MAPS_API_KEY=

# iOS OAuth client (Google Cloud Console → Credentials → OAuth client ID → iOS,
# bundle id com.nycstoop.app). Required for native Google sign-in in the iOS app.
VITE_GOOGLE_IOS_CLIENT_ID=
