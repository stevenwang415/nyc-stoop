# ── Database ──────────────────────────────────────────────────────────────
# Neon Postgres connection string. Get from the Neon dashboard → "Connection details".
# Use the pooled (PgBouncer) URL for Cloud Run. Example shape:
#   postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=
# ── JWT ───────────────────────────────────────────────────────────────────
# Random 32+ byte secret used to sign app JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET
# How long an issued JWT stays valid (minutes). 24h default.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Google OAuth ──────────────────────────────────────────────────────────
# Web client ID from Google Cloud Console → Credentials → OAuth 2.0 Client.
# Must match VITE_GOOGLE_CLIENT_ID on the frontend.
GOOGLE_CLIENT_ID=

# ── Resend (transactional email) ──────────────────────────────────────────
# API key from resend.com/api-keys
RESEND_API_KEY=
# Sender. Either your verified domain (recommended) or 'onboarding@resend.dev' in dev.
RESEND_FROM=NYC Stoop <onboarding@resend.dev>

# ── Frontend URL ──────────────────────────────────────────────────────────
# Used to build the password-reset link emailed to users.
# Local: http://localhost:5173 — Prod: https://nyc-stoop.vercel.app
FRONTEND_URL=http://localhost:5173

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser requests.
# Local + Vercel prod + any preview deploys.
CORS_ORIGINS=http://localhost:5173,https://nyc-stoop.vercel.app
